# ===========================================
# API Keys
# ===========================================

# Groq API Key (LLM for quiz generation)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=

# HuggingFace Token (Embeddings)
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=

# ===========================================
# MongoDB Atlas
# ===========================================

# MongoDB Connection String
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=

# Database name
MONGODB_DATABASE=quiz_tutor

# ===========================================
# Document Storage (Supabase optional)
# ===========================================

SUPABASE_URL=
# Either of these works (backend supports both names):
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=documents
SUPABASE_PUBLIC_URL_BASE=

# ===========================================
# Clerk (Authentication)
# ===========================================

CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# ===========================================
# App Configuration
# ===========================================

BACKEND_URL=http://localhost:8000
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:3001
FRONTEND_ORIGIN_REGEX=https://.*\.vercel\.app
ENVIRONMENT=development
LOG_LEVEL=INFO

# ===========================================
# Optional: SMTP for email reminders
# ===========================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# ===========================================
# Optional: Local model/cache directories
# ===========================================

HF_HOME=D:\hf_cache
HF_HUB_CACHE=D:\hf_cache\hub
SENTENCE_TRANSFORMERS_HOME=D:\hf_cache
